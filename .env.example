# 🔐 BITE STORE BOT — LOCAL ENV EXAMPLE
# Copy this file to .env and fill your own values.
# NEVER share/commit your real .env file.

# Required
BOT_TOKEN=your_telegram_bot_token_here
ADMIN_ID=your_telegram_user_id_here

# Optional but needed for AI Assistant / screenshot verifier
GEMINI_API_KEY=your_gemini_api_key_here

# Payment / verification email credentials
EMAIL_ADDRESS=your_easypaisa_or_smsforwarder_gmail@example.com
EMAIL_PASSWORD=your_gmail_app_password_here
BINANCE_EMAIL=your_binance_notification_gmail@example.com
BINANCE_EMAIL_PASSWORD=your_gmail_app_password_here

# Optional — Binance Pay REST API (v61 auto-detect, replaces Gmail scraping)
BINANCE_API_KEY=
BINANCE_API_SECRET=
# 🌐 v61: Pakistani / allowed-region HTTPS or SOCKS5 proxy.
# Binance returns HTTP 451 on Render (US) without this. Examples:
#   http://user:pass@pk-proxy.example.com:8080
#   socks5://user:pass@pk-proxy.example.com:1080
BINANCE_PROXY_URL=
# 🆕 v63: Multiple proxies (comma-separated) — auto-rotated with 5-min cooldown.
# Use this instead of (or alongside) BINANCE_PROXY_URL for high reliability.
#   BINANCE_PROXY_LIST=socks5://a:1080,socks5://b:1080,http://c:8080
BINANCE_PROXY_LIST=
# Optional — override default Binance API base (e.g. api1/api2/api3 / GCP)
BINANCE_API_BASE=

TELEGRAM_PROXY=
DB_PATH=shop.db
WEBHOOK_URL=
ARENA_API_KEY=
ARENA_API_URL=https://api.openai.com/v1/chat/completions
ARENA_MODEL=gpt-4o-mini

# Optional API security
API_WEBHOOK_SECRET=change_me_for_external_webhooks
API_SECRET_ENCRYPTION_KEY=change_me_for_external_api_key_encryption
